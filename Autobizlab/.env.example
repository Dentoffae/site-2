# Скопируйте в .env и задайте свои значения:
#   cp .env.example .env

# PostgreSQL
POSTGRES_USER=autobizlab
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=autobizlab

# pgAdmin (вход в веб-интерфейс)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_strong
# Подключение к БД в UI: правьте pgadmin/servers.json под POSTGRES_USER / POSTGRES_DB (пароль вводится при первом входе на сервер)

# Registry (Docker Distribution): push/pull с локальной машины через тот же хост, что и сайт (Nginx → /v2/).
#   docker login http://<IP_или_домен_сервера>   # логин/пароль из registry/auth/htpasswd
#   docker tag myapp:latest <хост>/autobizlab-backend:latest && docker push <хост>/autobizlab-backend:latest
# Создать пользователя: apt install apache2-utils && htpasswd -B registry/auth/htpasswd <user>
# HTTP без TLS: в /etc/docker/daemon.json на клиенте — "insecure-registries": ["<IP_или_домен>"], затем restart docker
#
# Фронт отправляет заявки на POST /api/v1/leads через Nginx → сервис backend (порт 8080 не публикуется наружу).
# В compose для backend задаётся DATABASE_URL с драйвером postgresql+psycopg://…
